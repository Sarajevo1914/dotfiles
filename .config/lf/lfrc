#!/bin/sh

# zoxide maybe is to cost to performance
# req trash-cli
# wl-copy for wayland
# xclip for x11

# Basic settings
set autoquit true
set shell sh
set shellopts '-eu'
set ifs "\n"
set scrolloff 10
set sortby name
set ignorecase true
set period 1
set mouse true
set ratios '1:2'

### LF PREVIEWS
