# cmd/funcions

cmd open &{{
    for file in $fx; do
        case $(file --mime-type -Lb "$file") in
            text/*)
                lf -remote "send $id \$EDITOR \"$file\""
                ;;
            *)
                ${OPENER:-xdg-open} "$file" >/dev/null 2>&1 &
                ;;
        esac
    done
}}

cmd mkdir ${{
    printf "Directory name(s): "
    read -r ans
    [ -z "$ans" ] && exit 0
    mkdir -p -- $ans && echo "Created: $ans"
}}

cmd delete ${{
    clear
    tput cup $(($(tput lines)/3))
    printf "Delete files:\n"
    printf "%s\n" "$fx"
    printf "\nConfirm deletion? [y/N] "
    read -r ans
    case $ans in
        [Yy]*)
            if command -v trash-put >/dev/null 2>&1; then
                trash-put -- $fx
                lf -remote "send $id echo 'Files moved to trash'"
            else
                printf "trash-cli not found, permanently delete? [y/N] "
                read -r confirm
                case $confirm in
                    [Yy]*)
                        [ -n "$fx" ] && rm -rf -- $fx
                        lf -remote "send $id echo 'Files permanently deleted'"
                        ;;
                    *) lf -remote "send $id echo 'Aborted'";;
                esac
            fi
            ;;
        *) lf -remote "send $id echo 'Aborted'";;
    esac
}}

cmd copy-name ${{
    names=$(basename -a -- $fx)
    if [ -n "${WAYLAND_DISPLAY:-}" ]; then
        printf '%s' "$names" | wl-copy
    elif [ -n "${DISPLAY:-}" ]; then
        printf '%s' "$names" | xclip -selection clipboard
    else
        lf -remote "send $id echoerr 'No clipboard manager found'"
    fi
}}

cmd copy-path ${{
    paths=$(realpath -- $fx)
    if [ -n "${WAYLAND_DISPLAY:-}" ]; then
        printf '%s' "$paths" | wl-copy
    elif [ -n "${DISPLAY:-}" ]; then
        printf '%s' "$paths" | xclip -selection clipboard
    else
        lf -remote "send $id echoerr 'No clipboard manager found'"
    fi
}}

# Opt back into the statfmt/rulerfmt system (required in r41+)
set rulerfmt "%a|%p| \033[7;31m %m \033[0m| \033[7;33m %c \033[0m| \033[7;35m %s \033[0m| \033[7;34m %f \033[0m| %i/%t"

cmd on-select &{{
    if command -v eza >/dev/null 2>&1; then
        info=$(eza -lbdg --time-style long-iso --color=always "$f")
        lf -remote "send $id set statfmt \"$info\""
        if [ -d "$f" ]; then
            info=$(eza -lbdg --total-size --time-style long-iso --color=always "$f")
            lf -remote "send $id set statfmt \"$info\""
        fi
    else
        info=$(ls -ld "$f")
        lf -remote "send $id set statfmt \"$info\""
    fi
    command -v zoxide >/dev/null 2>&1 && zoxide add "$PWD"
}}

# Keybidings
map <enter> shell
map q quit

# Movements
map k up
map j down
map h updir
map l open
map <up> up
map <down> down
map <left> updir
map <right> open

map <c-b> page-up
map <c-f> page-down
